# Copy to `.env.local` for local dev; set the same keys in Vercel Project Settings.
# Only NEXT_PUBLIC_* reach the browser. See docs/SETUP.md for where each value comes from.

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Personal access token (Account → Access Tokens), for running DB migrations. App doesn't use it.
SUPABASE_ACCESS_TOKEN=

# ── HubSpot ───────────────────────────────────────────────────────────────
HUBSPOT_TOKEN=
HUBSPOT_PORTAL_ID=

# ── Plausible ─────────────────────────────────────────────────────────────
PLAUSIBLE_API_KEY=

# ── Screenshots (Microlink) ───────────────────────────────────────────────
# Optional — free tier needs no key. Set only on Microlink Pro.
SCREENSHOT_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────
APP_BASE_URL=https://decks.tristargroup.us
# Secret for the hourly cron backstop (/api/cron/sweep). Generate a random string;
# Vercel Cron sends it as a Bearer token. If unset, the route needs an admin session.
CRON_SECRET=
# Bearer token the prospecting skill uses to POST run output to /api/prospecting/ingest.
# If unset, that endpoint requires an admin session.
PROSPECTING_INGEST_SECRET=
